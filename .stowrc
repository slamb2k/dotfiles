--target=~/.config
--ignore=.stowrc
--ignore=DS_Store
--ignore=atuin/*

# Top-level repo machinery — not config files
--ignore=^install\.(sh|ps1)$
--ignore=^setup\.(sh|ps1)$
--ignore=^test\.ps1$
--ignore=^README\.md$

# Platform-specific installer payloads, not Linux configs
--ignore=^linux$
--ignore=^windows$

# Home-targeted package — handled separately in setup.sh
--ignore=^claude$
