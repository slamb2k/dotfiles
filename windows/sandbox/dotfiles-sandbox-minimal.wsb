<Configuration>
  <!--
    Minimal-test variant of dotfiles-sandbox.wsb.

    Runs configuration.dsc.minimal.yaml (WSL + Ubuntu + Git + Pwsh +
    Terminal — ~12 resources, 3-5 min). Use for fast iteration; use
    dotfiles-sandbox.wsb for end-to-end machine-restoration tests.

    Inside the sandbox you'll see a PowerShell window with live progress.
    Two diagnostic files appear:
      C:\sandbox-marker.txt       proves LogonCommand fired
      C:\sandbox-bootstrap.log    full transcript of bootstrap.ps1
    Tail from another window:  Get-Content C:\sandbox-bootstrap.log -Wait

    The LogonCommand uses -EncodedCommand (UTF-16-LE base64) instead of
    nested cmd /c "start "" powershell -Command """""..." quoting,
    which 26200 builds mangle silently.
  -->
  <Networking>Default</Networking>
  <vGPU>Disable</vGPU>
  <MemoryInMB>16384</MemoryInMB>
  <ClipboardRedirection>true</ClipboardRedirection>
  <ProtectedClient>false</ProtectedClient>
  <LogonCommand>
    <Command>powershell.exe -NoExit -ExecutionPolicy Bypass -EncodedCommand </Command>
  </LogonCommand>
</Configuration>
