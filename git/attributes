# Global gitattributes.
# Force LF line endings for text; keep known-binary formats binary.

* text=auto eol=lf

# Shell / config
*.sh         text eol=lf
*.bash       text eol=lf
*.zsh        text eol=lf
*.fish       text eol=lf
*.ps1        text eol=crlf

# Docs
*.md         text
*.txt        text
*.json       text
*.yaml       text
*.yml        text
*.toml       text

# Explicit binary (avoid accidental text conversion)
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.webp       binary
*.ico        binary
*.pdf        binary
*.zip        binary
*.tar        binary
*.gz         binary
*.xz         binary
*.7z         binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.otf        binary
*.sqlite     binary
*.db         binary
